PORT=8123
BASE_URL=http://localhost:8123

# Create these in Meta Developers.
META_APP_ID=your_meta_app_id
META_APP_SECRET=your_meta_app_secret

# Simplest test mode: paste a Meta token with ads_read.
# If this is filled, the dashboard can run without OAuth.
META_ACCESS_TOKEN=
META_AD_ACCOUNT_IDS=act_123456789,act_987654321

# TikTok simple connector placeholders.
TIKTOK_APP_ID=
TIKTOK_APP_SECRET=
TIKTOK_REDIRECT_URI=
TIKTOK_ACCESS_TOKEN=
TIKTOK_ADVERTISER_IDS=

# Google Ads connector placeholders.
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_ACCESS_TOKEN=
GOOGLE_ADS_LOGIN_CUSTOMER_ID=
GOOGLE_ADS_CUSTOMER_IDS=

# Keep this configurable because Meta Graph API versions change over time.
META_GRAPH_VERSION=v24.0
